{
  "manifest_version": 2,
  "name": "Applied",
  "version": "2.1.0",
  "description": "Smart, one-click job application assistant.",
  "icons": {
    "128": "logo.svg"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "https://*/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "Applied",
    "default_icon": "logo.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "applied@haroon.dev"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content-script.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}